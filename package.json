{
  "name": "notes-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint . --fix",
    "format": "npx prettier -w .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "docker:dev:build": "docker-compose -f docker-compose/docker-compose.dev.yml up --build",
    "docker:dev:start": "docker-compose -f docker-compose/docker-compose.dev.yml up",
    "docker:dev:stop": "docker-compose -f docker-compose/docker-compose.dev.yml down",
    "docker:prod:build": "docker-compose -f docker-compose/docker-compose.prod.yml up --build",
    "docker:prod:start": "docker-compose -f docker-compose/docker-compose.prod.yml up -d",
    "docker:prod:stop": "docker-compose -f docker-compose/docker-compose.prod.yml down"
  },
  "dependencies": {
    "@ant-design/icons": "6",
    "@hookform/resolvers": "^5.2.2",
    "@tailwindcss/vite": "^4.1.11",
    "@tanstack/react-query": "^5.80.7",
    "@tanstack/react-query-devtools": "^5.90.2",
    "antd": "6",
    "axios": "^1.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "create-gstore": "^0.2.0",
    "jwt-decode": "^4.0.0",
    "lucide-react": "^0.525.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.71.2",
    "react-router-dom": "^7.6.2",
    "styled-components": "^6.1.19",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.11",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/styled-components": "^5.1.35",
    "@vitejs/plugin-react": "^4.4.1",
    "@vitest/coverage-v8": "^4.0.15",
    "babel-plugin-styled-components": "^2.1.4",
    "eslint": "^9.25.0",
    "eslint-import-resolver-typescript": "^4.4.3",
    "eslint-plugin-boundaries": "^5.0.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "jsdom": "^27.2.0",
    "prettier": "^3.5.3",
    "tw-animate-css": "^1.3.4",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.15"
  }
}
